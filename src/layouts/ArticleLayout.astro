---
// src/layouts/ArticleLayout.astro
import RootLayout from './RootLayout.astro';
const { frontmatter } = Astro.props;
---

<RootLayout title={`${frontmatter.title} | Austin Allison`}>
  
  <!-- Warm Regional Header Block -->
  <div class="w-full bg-sage/10 border-l-4 border-sage p-6 md:p-8 rounded-sm mb-10">
    <div class="flex items-center gap-2 text-xs font-mono text-sage uppercase tracking-wider mb-2 font-semibold">
      <span>{frontmatter.publication}</span>
      <span>&bull;</span>
      <span>{frontmatter.date}</span>
    </div>
    <h1 class="font-serif text-2xl md:text-3xl font-medium tracking-tight text-iron leading-tight">
      {frontmatter.title}
    </h1>
  </div>

  <!-- Main Article Body -->
  <article class="max-w-2xl mx-auto text-iron">
    <slot />
    
    <!-- Back Navigation Rule -->
    <div class="mt-16 pt-6 border-t border-haze">
      <a href="/publications" class="text-xs font-mono text-caprock hover:underline lowercase tracking-wide inline-flex items-center gap-1">
        &larr; return to repository index
      </a>
    </div>
  </article>

</RootLayout>