---
// src/layouts/RootLayout.astro
import '../styles/global.css';
import { Image } from 'astro:assets';
import signature from '../assets/signature.svg';
import Header from '../components/Header.astro'; // IMPORT THE NEW HEADER HERE
import Footer from '../components/Footer.astro'; // IMPORT THE NEW HEADER HERE

interface Props {
	title: string;
	description?: string;
}

const { title, hideNav = false, description = "Academic Librarian & Photographer Portfolio" } = Astro.props;
// Get the current path (e.g., "/projects/ocr-pipeline")
const currentPath = Astro.url.pathname;
// Split into array and remove empty strings
const pathSegments = currentPath.split('/').filter(segment => segment !== '');
---

<!DOCTYPE html>
<html lang="en" class="bg-canvas text-iron antialiased scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<meta name="description" content={description} />
	</head>
	<body class="min-h-screen flex flex-col selection:bg-caprock/20 selection:text-caprock">
		
{!hideNav && <Header />}

<!-- The main page content container -->
	<main class="flex-grow w-full max-w-7xl mx-auto px-6 py-12">

  		<div class="prose prose-neutral max-w-none font-sans">
    	<slot />
  		</div>
		</main>

<!-- The Large-Format Film Rebate & Geodetic Matrix -->

<footer class="relative w-full overflow-hidden bg-canvas text-[var(--color-canvas)] py-8 md:py-12 px-4 sm:px-6 font-sans border-t border-[var(--color-canvas)]/10 select-none">
  
  <!-- 01: THE AMBIENT DESERT HAZE -->
  

  <!-- 02: THE COMPACT BENTO GRID -->
  <div class="relative z-10 w-full max-w-6xl mx-auto flex flex-col gap-3">
    
    <div class="grid grid-cols-1 md:grid-cols-12 gap-3">
      
      <!-- Primary Module: Brand & Status -->
      <div class="col-span-12 md:col-span-7 bg-[var(--color-sage)] border border-[var(--color-canvas)]/[0.06] rounded-2xl p-6 md:p-8 backdrop-blur-2xl flex flex-col justify-between hover:bg-[var(--color-sage)]/[0.86] transition-all duration-700 group shadow-lg shadow-black/20">
        <div>
          <h2 class="text-2xl md:text-3xl lg:text-4xl font-serif font-medium tracking-tight text-[var(--color-canvas)] mb-2 group-hover:text-[var(--color-dust)] transition-colors duration-500">
            Austin Allison
          </h2>
          <p class="text-xs md:text-sm text-[var(--color-canvas)]/60 max-w-sm font-light leading-relaxed">
            Cataloging and Metadata Librarian &bull; Historian &bull; Photographer
          </p>
          <p class="text-xs md:text-sm text-[var(--color-canvas)]/60 max-w-sm font-light leading-relaxed">
            Southwest Collection/Special Collections Library
          </p>
		  <p class="text-xs md:text-sm text-[var(--color-canvas)]/60 max-w-sm font-light leading-relaxed">
            Texas Tech University
          </p>
        </div>
        
        <div class="flex items-center gap-3 mt-8 md:mt-12">
          <div class="relative flex h-2 w-2">
            <!-- Ping animation element can go here -->
          </div>
          <span class="text-[9px] md:text-[10px] uppercase tracking-[0.2em] font-mono text-[var(--color-dust)]">
            Website constructed using Visual Studio Code, Tailwind CSS, and Astro 7.1 web framework.
          </span>
        </div>
      </div>

      <!-- Secondary Module: Tighter Navigation -->
      <div class="col-span-12 md:col-span-5 bg-[var(--color-sage)] border border-[var(--color-canvas)]/[0.06] rounded-2xl p-6 md:p-8 backdrop-blur-2xl flex flex-col justify-between hover:bg-[var(--color-sage)]/[0.86] transition-all duration-700 shadow-lg shadow-black/20">
        <div class="text-[9px] md:text-[10px] uppercase tracking-[0.2em] text-[var(--color-canvas)] font-mono mb-4 md:mb-6 flex items-center gap-2">
          <span class="text-[var(--color-dust)]">// //</span> Website Index <span class="text-[var(--color-dust)]">\\ \\</span>
        </div>
        
        <nav class="flex flex-col gap-3 md:gap-4 text-base md:text-lg font-light tracking-wide">
          <a href="/photography" class="text-[var(--color-canvas)]/70 hover:text-[var(--color-dust)] hover:translate-x-1.5 transition-all duration-300 flex items-center justify-between group">
            <span>Photography</span>
            <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-[var(--color-caprock)] text-xs md:text-sm">&rarr;</span>
          </a>
          <a href="/publications" class="text-[var(--color-canvas)]/70 hover:text-[var(--color-dust)] hover:translate-x-1.5 transition-all duration-300 flex items-center justify-between group">
            <span>Scholarly Publications</span>
            <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-[var(--color-caprock)] text-xs md:text-sm">&rarr;</span>
          </a>
          <a href="/cv" class="text-[var(--color-canvas)]/70 hover:text-[var(--color-dust)] hover:translate-x-1.5 transition-all duration-300 flex items-center justify-between group">
            <span>Curriculum Vitae</span>
            <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-[var(--color-caprock)] text-xs md:text-sm">&rarr;</span>
          </a>
        </nav>
      </div>
      
      <!-- 02.5: WAYFINDING / BREADCRUMBS (DYNAMIC ASTRO MODULE) -->
      <div class="col-span-12 bg-[var(--color-sage)] border border-[var(--color-canvas)]/[0.04] rounded-xl p-3 md:px-6 backdrop-blur-xl flex flex-wrap items-center gap-2 font-mono text-[9px] md:text-[10px] uppercase tracking-widest text-[var(--color-canvas)]/50 shadow-sm">
        <span class="text-[var(--color-dust)] mr-2">// Breadcrumbs //</span>
        <a href="/" class="text-[var(--color-dust)] hover:text-[var(--color-dust)] transition-colors">root</a>
        
        {pathSegments.length > 0 && pathSegments.map((segment, index) => {
          // Rebuild the URL path up to the current segment
          const href = `/${pathSegments.slice(0, index + 1).join('/')}`;
          // Clean up the text (e.g., 'ocr-pipeline' -> 'ocr pipeline')
          const label = segment.replace(/-/g, ' ');
          
          return (
            <div class="flex items-center gap-2">
              <span class="text-[var(--color-canvas)]/20">/</span>
              <a href={href} class="hover:text-[var(--color-dust)] transition-colors">
                {label}
              </a>
            </div>
          );
        })}
      </div>

    </div>

    <!-- 03: THE HORIZON STRIP -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-1">
      <!-- Locality / Comm Module -->
      <div class="bg-[var(--color-sage)] border border-[var(--color-canvas)]/[0.04] rounded-xl p-4 md:px-6 backdrop-blur-xl flex flex-wrap items-center justify-between gap-3 text-[10px] md:text-xs font-mono text-[var(--color-canvas)]/80 hover:bg-[var(--color-sage)]/[0.86] transition-colors duration-500">
        <a href="mailto:austinlallison@gmail.com" class="hover:text-[var(--color-dust)] transition-colors">austinlallison@gmail.com</a>
      </div>
      
      <!-- Legal / Copyright Module -->
      <div class="bg-[var(--color-sage)] border border-[var(--color-canvas)]/[0.04] rounded-xl p-4 md:px-6 backdrop-blur-xl flex items-center justify-center md:justify-end text-[10px] md:text-xs font-mono text-[var(--color-canvas)]/80 hover:text-[var(--color-canvas)]/50 transition-colors duration-500">
        &copy; {new Date().getFullYear()} Austin Allison. All Rights Reserved.
      </div>
    </div>

  </div>
</footer>
	</body>
</html>
<style is:global>
  /* Premium architectural easing for the sliding bounding box */
  #active-loupe {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), width 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease-out;
  }
</style>

<!-- Kinetic Loupe Tracking Engine -->
<script>
  const nav = document.getElementById('loupe-nav');
  const loupe = document.getElementById('active-loupe');
  const nodes = document.querySelectorAll('.nav-node');

  if (nav && loupe && nodes.length > 0) {
    nodes.forEach(node => {
      node.addEventListener('mouseenter', (e) => {
        const target = e.currentTarget as HTMLElement;
        
        // Calculate dynamic bounding box relative to the nav container
        const navRect = nav.getBoundingClientRect();
        const targetRect = target.getBoundingClientRect();
        
        const leftPos = targetRect.left - navRect.left;
        const targetWidth = targetRect.width;

        // Slide the loupe and snap its width perfectly around the hovered word
        loupe.style.opacity = '1';
        loupe.style.transform = `translateX(${leftPos}px)`;
        loupe.style.width = `${targetWidth}px`;
      });
    });

    // Reset smoothly when the cursor leaves the navigation area entirely
    nav.addEventListener('mouseleave', () => {
      loupe.style.opacity = '0';
    });
  }
</script>