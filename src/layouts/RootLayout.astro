---
// src/layouts/RootLayout.astro
import '../styles/global.css';
import { Image } from 'astro:assets';
import signature from '../assets/signature.svg';
import Header from '../components/Header.astro'; // IMPORT THE NEW HEADER HERE
import Footer from '../components/Footer.astro'; // IMPORT THE NEW HEADER HERE

interface Props {
	title: string;
	description?: string;
}

const { title, hideNav = false, hideFoot = false, description = "Academic Librarian & Photographer Portfolio" } = Astro.props;
// Get the current path (e.g., "/projects/ocr-pipeline")
const currentPath = Astro.url.pathname;
// Split into array and remove empty strings
const pathSegments = currentPath.split('/').filter(segment => segment !== '');
---

<!DOCTYPE html>
<html lang="en" class="bg-canvas text-iron antialiased scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<meta name="description" content={description} />
	</head>
	<body class="min-h-screen flex flex-col selection:bg-caprock/20 selection:text-caprock">
		
{!hideNav && <Header />}

<!-- The main page content container -->
	<main class="flex-grow w-full max-w-7xl mx-auto px-6 py-12">

  		<div class="prose prose-neutral max-w-none font-sans">
    	<slot />
  		</div>
		</main>

<!-- The Large-Format Film Rebate & Geodetic Matrix -->

<!-- The Large-Format Film Rebate & Geodetic Matrix -->
{!hideFoot && (
  <Footer>
    <Fragment slot="signature" set:html={signature} />
  </Footer>
)}

	</body>
</html>
<style is:global>
  /* Premium architectural easing for the sliding bounding box */
  #active-loupe {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), width 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease-out;
  }
</style>

<!-- Kinetic Loupe Tracking Engine -->
<script>
  const nav = document.getElementById('loupe-nav');
  const loupe = document.getElementById('active-loupe');
  const nodes = document.querySelectorAll('.nav-node');

  if (nav && loupe && nodes.length > 0) {
    nodes.forEach(node => {
      node.addEventListener('mouseenter', (e) => {
        const target = e.currentTarget as HTMLElement;
        
        // Calculate dynamic bounding box relative to the nav container
        const navRect = nav.getBoundingClientRect();
        const targetRect = target.getBoundingClientRect();
        
        const leftPos = targetRect.left - navRect.left;
        const targetWidth = targetRect.width;

        // Slide the loupe and snap its width perfectly around the hovered word
        loupe.style.opacity = '1';
        loupe.style.transform = `translateX(${leftPos}px)`;
        loupe.style.width = `${targetWidth}px`;
      });
    });

    // Reset smoothly when the cursor leaves the navigation area entirely
    nav.addEventListener('mouseleave', () => {
      loupe.style.opacity = '0';
    });
  }
</script>