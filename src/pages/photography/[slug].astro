---
// src/pages/photography/[slug].astro
import Layout from '../../layouts/RootLayout.astro';

export async function getStaticPaths() {
  const galleries = [
    {
      slug: 'escarpments',
      number: 'I',
      title: 'American Escarpments',
      region: 'Texas | Montana | Washington',
      essay: 'From the rugged Permian red beds of the Southern Plains to the ancient volcanic chasms of the Pacific Northwest and the dramatic glacial coulees of Montana’s Big Sky country, this photo set captures the breathtaking geological fractures that define the American West. These landscapes are a masterclass in geomorphology, visually documenting the diverse forces of water, wind, and ancient cataclysms that have sculpted the continent’s vast interior tablelands. By showcasing the abrupt transitions where endless high prairies drop away into hidden canyons, valleys, and river floors, the collection highlights both the immense isolation and the unexpected productivity of the Western terrain. Ultimately, the images serve as a striking testament to human adaptation, where ancient natural fortresses and challenging migratory barriers have seamlessly transformed into modern landscapes of recreation and massive agricultural abundance.',
      centerX: 1550, 
      centerY: 920,
      plates: [
        {
          src: '/images/escarpments/escarpment1.jpg',
          title: 'Little Jerusalem Hoodoos · Toole County, Montana',
          coordinates: '48.968683° N, 111.982261° W',
          specs: '12mm · ƒ/8 · 1/320s',
          coordsClass: 'top-[120px] left-[680px] w-[560px]',
          caption: ''
        },
        {
          src: '/images/escarpments/escarpment2.jpg',
          title: 'Blooming Stratification · Garza County, Texas',
          coordinates: '33.090300° N, 101.500369° W',
          specs: '14mm · ƒ/8 · 1/320s',
          coordsClass: 'top-[680px] left-[290px] w-[450px]',
          caption: ''
        },
        {
          src: '/images/escarpments/escarpment3.jpg',
          title: 'Palouse Canyon Basalt · Franklin and Whitman counties, Washington',
          coordinates: '46.662612° N, 118.227612° W',
          specs: '14mm · ƒ/8 · 1/100s',
          coordsClass: 'top-[840px] left-[770px] w-[520px]',
          caption: ''
        },
        {
          src: '/images/escarpments/escarpment4.jpg',
          title: 'The Sea of Red and Cedar · Briscoe County, Texas',
          coordinates: '34.465959° N, 101.098786° W',
          specs: '12mm · ƒ/2.8 · 1/2000s',
          coordsClass: 'top-[180px] left-[1275px] w-[500px]',
          caption: ''
        },
        {
          src: '/images/escarpments/escarpment5.jpg',
          title: 'Little Jerusalem Hoodoos · Toole County, Montana',
          coordinates: '48.968683° N, 111.982261° W',
          specs: '12mm · ƒ/3.5 · 1/1250s',
          coordsClass: 'top-[870px] left-[1310px] w-[340px]',
          caption: ''
        },
        {
          src: '/images/escarpments/escarpment6.jpg',
          title: 'Upper Yellow House Draw Canyon · Bailey County, Texas',
          coordinates: '33.851419° N, 102.700752° W',
          specs: '12mm · ƒ/2.8 · 1/2000s',
          coordsClass: 'top-[420px] left-[1830px] w-[400px]',
          caption: ''
        },
        {
          src: '/images/escarpments/escarpment7.jpg',
          title: 'Little Jerusalem with Sweetgrass Hills · Toole County, Montana',
          coordinates: '48.966829° N, 111.965596° W',
          specs: '12mm · ƒ/2.8 · 1/200s',
          coordsClass: 'top-[700px] left-[1850px] w-[540px]',
          caption: ''
        },
        {
          src: '/images/escarpments/escarpment8.jpg',
          title: 'Hoodoos at Little Jerusalem · Toole County, Montana',
          coordinates: '48.966829° N, 111.965596° W',
          specs: '12mm · ƒ/8 · 1/320s',
          coordsClass: 'top-[350px] left-[160px] w-[500px]',
          caption: 'The Hoodoos!'
        },
        {
          src: '/images/escarpments/escarpment9.jpg',
          title: 'Beige Chasm · Garza County, Texas',
          coordinates: '33.090300° N, 101.500369° W',
          specs: '14mm · ƒ/8 · 1/320s',
          coordsClass: 'top-[1050px] left-[1700px] w-[600px]',
          caption: ''
        },
        {
          src: '/images/escarpments/escarpment10.jpg',
          title: 'Walls of the Pecos · Val Verde County, Texas',
          coordinates: '29.720860° N, 101.347319° W',
          specs: '12mm · ƒ/5.6 · 1/1000s',
          coordsClass: 'top-[1050px] left-[370px] w-[360px]',
          caption: ''
        },
        {
          src: '/images/escarpments/escarpment11.jpg',
          title: 'Brazos Headwaters · Garza County, Texas',
          coordinates: '33.090300° N, 101.500369° W',
          specs: '12mm · ƒ/5.6 · 1/1000s',
          coordsClass: 'top-[500px] left-[750px] w-[1060px]',
          caption: ''
        }
      ]
    },
    {
      slug: 'water_on_the_llano_estacado',
      number: 'II',
      title: 'Water on the Llano Estacado',
      region: 'Texas | New Mexico',
      essay: '',
      centerX: 1250, 
      centerY: 820,
      plates: [
        {
          src: '/images/water/water1.jpg',
          title: 'Tule Creek Flow · Briscoe County, Texas',
          coordinates: '34.54667° N, 101.429921° W',
          specs: '12mm · ƒ/8 · 1/320s',
          coordsClass: 'top-[250px] left-[750px] w-[250px]',
          caption: ''
        },
        {
          src: '/images/water/water2.jpg',
          title: 'Canadian River Boundary · Hemphill County, Texas',
          coordinates: '35.937055° N, 100.369943° W',
          specs: '12mm · ƒ/5.6 · 1/500s',
          coordsClass: 'top-[200px] left-[320px] w-[400px]',
          caption: 'The Canadian River signifies the northern extent of the Llano Estacado for much of its northern extent. This view in Hemphill County shows the meandering river at sunset.'
        },
        {
          src: '/images/water/water3.jpg',
          title: 'Active Runningwater Draw · Parmer County, Texas',
          coordinates: '34.471036° N, 102.720865° W', 
          specs: '12mm · ƒ/5.6 · 1/640s',
          coordsClass: 'top-[180px] left-[1100px] w-[400px]',
          caption: ''
        },
        {
          src: '/images/water/water4.jpg',
          title: 'Colorful Basin · Bailey County, Texas',
          coordinates: '33.991164° N, 102.708448° W',
          specs: '12mm · ƒ/2.8 · 1/3200s',
          coordsClass: 'top-[480px] left-[1080px] w-[400px]',
          caption: ''
        }
      ]
    }
  ];

  return galleries.map((gallery) => ({
    params: { slug: gallery.slug },
    props: { gallery }
  }));
}

const { gallery } = Astro.props;
---

<Layout title={`${gallery.title} — Austin Allison`} hideNav={true}>
  <!-- touch-none applied to prevent mobile browsers from hijacking swipes -->
    <main 
      id="workspace-viewport" 
      class="w-screen h-[100dvh] overflow-hidden bg-canvas text-iron select-none cursor-grab active:cursor-grabbing relative touch-none"
    >
      
      <!-- Fixed Editorial HUD Overlay (Responsive, Collapsing, & Expandable) -->
      <div 
      id="fixed-hud-container"
      class="fixed top-4 left-4 right-4 md:top-8 md:left-8 md:right-8 z-50 flex justify-between items-start pointer-events-none gap-4">
        <div 
          id="hud-overlay" 
          class="pointer-events-auto w-full max-w-[65%] md:max-w-sm bg-canvas/95 backdrop-blur-xs p-4 md:p-6 border border-haze rounded-sm shadow-lg transition-all duration-300"
        >
          <div class="flex items-center justify-between gap-2 mb-1 md:mb-2">
            
            <button 
              id="hud-toggle" 
              class="md:hidden font-mono text-[9px] uppercase tracking-widest text-iron/50 hover:text-caprock transition-colors flex items-center gap-1 focus:outline-none shrink-0"
              aria-expanded="false"
            >
              <span id="toggle-text">info</span>
              <span id="toggle-icon" class="transition-transform duration-300 inline-block">+</span>
            </button>
          </div>
        <div class="flex items-center -mt-3 space-x-2 text-[9px] md:text-[10px] font-mono text-sage uppercase tracking-widest truncate">
              <span class="hidden md:inline">{gallery.region}</span>
        </div>
          <h2 class="font-serif text-md md:text-2xl font-light tracking-tight text-sage mb-1 md:mb-3 mt-1 truncate md:whitespace-normal">
            Series {gallery.number}.
          </h2>
          <h1 class="font-serif text-lg md:text-2xl font-light tracking-tight text-caprock mb-1 md:mb-3 truncate md:whitespace-normal -mt-2">
             {gallery.title}.
          </h1>
          
          <div id="hud-collapsible" class="hidden md:block transition-all duration-300 overflow-hidden">
            <p class="font-serif italic text-xs text-iron/70 leading-relaxed mt-2 md:mt-0 mb-4">
              {gallery.essay}
            </p>
            <p class="md:hidden font-mono text-[9px] text-sage uppercase tracking-widest mb-4">
              {gallery.region}
            </p>
            
            <nav class="flex flex-col gap-1.5 mt-4 border-t border-haze/40 pt-4 pb-2">
              <span class="font-mono text-[9px] uppercase tracking-widest text-iron/40 mb-1">Series Registry</span>
              <a href="/photography/escarpments" class="font-mono text-[10px] text-sage hover:text-caprock transition-colors truncate">I. American Escarpments</a>
              <a href="/photography/water_on_the_llano_estacado" class="font-mono text-[10px] text-sage hover:text-caprock transition-colors truncate">II. Water on the Llano Estacado</a>
              <a href="/photography/cotton_gins_of_texas" class="font-mono text-[10px] text-sage hover:text-caprock transition-colors truncate">III. Cotton Gins of Texas</a>
            </nav>
          </div>
          
          <div class="hidden md:flex font-mono text-[10px] uppercase tracking-wider text-caprock items-center gap-2 mt-2">
            <span class="animate-pulse">●</span> Scroll and drag to navigate
          </div>
          <div class="hidden md:flex font-mono text-[10px] uppercase tracking-wider text-caprock items-center gap-2">
            <span class="animate-pulse">●</span> Click to open
          </div>

          <div 
            id="mobile-instructions" 
            class="hidden md:hidden font-mono text-[9px] uppercase tracking-wider text-sage/80 items-center gap-2 border-t border-haze/30 pt-3 mt-1"
          >
            <span class="animate-pulse">●</span> Pinch and drag to explore. Click to open.
          </div>
        </div>

        <div class="pointer-events-auto shrink-0">
          <a 
            href="/photography" 
            class="font-mono text-[9px] md:text-[10px] lowercase tracking-wide bg-caprock/80 backdrop-blur-xs px-3 py-1.5 md:px-4 md:py-2 border border-haze rounded-sm text-canvas hover:text-caprock hover:bg-canvas transition-colors shadow-xs block"
          >
            &larr; close<span class="hidden sm:inline"> album</span>
          </a>
        </div>
      </div>

      <!-- THE MOUNT DESK SURFACE -->
      <div 
        id="light-table" 
        class="absolute w-[3200px] h-[2200px] bg-topo-canvas pointer-events-auto origin-top-left will-change-transform"
        data-center-x={gallery.centerX}
        data-center-y={gallery.centerY}
      >
        
        <!-- Spatial Artifacts: The Photo Prints -->
        {gallery.plates.map((plate, index) => (
          <div 
            class={`absolute ${plate.coordsClass} flex flex-col group pointer-events-auto cursor-pointer`}
            data-lightbox-trigger
            data-index={index}
            data-src={plate.src}
            data-title={plate.title}
            data-specs={plate.specs}
            data-coords={plate.coordinates}
            data-caption={plate.caption || "No archival notes registered for this station log entry."}
            data-plate={`Plate ${String(index + 1).padStart(2, '0')}`}
          >
            <div class="border border-iron/10 p-3 bg-dust/35 shadow-md rounded-sm overflow-hidden transition-all duration-500 group-hover:shadow-xl group-hover:border-caprock/30">
              <div class="overflow-hidden bg-iron/5 pointer-events-none">
                <img src={plate.src} alt={plate.title} loading="lazy" decoding="async" class="w-full h-auto object-cover opacity-95 group-hover:opacity-100 transition-all duration-700" draggable="false" />
              </div>
            </div>
            <div class="w-full flex justify-between items-baseline text-[10px] font-mono text-sage uppercase tracking-wider mt-2 px-1">
              <span class="font-semibold text-iron/70">Plate {String(index + 1).padStart(2, '0')}</span>
              <span>{plate.coordinates}</span>
            </div>
          </div>
        ))}

      </div>

      <!-- Lightbox Layer Frame -->
      <div 
        id="lightbox-modal" 
        class="fixed inset-0 z-[100] h-[100dvh] bg-canvas/98 backdrop-blur-md hidden opacity-0 flex flex-col justify-between p-4 md:p-8 transition-opacity duration-300 select-none touch-auto"
      >
        <!-- Top Toolbar (Locks to Top) -->
        <div class="w-full max-w-7xl mx-auto flex justify-between items-center shrink-0">
          
          <!-- Toolbar (Progress + Explicit Zoom Controls) -->
          <div class="font-mono text-[10px] uppercase tracking-widest text-iron/50 flex items-center gap-3 md:gap-6">
            <span id="lightbox-progress"></span>
            
            <div class="flex items-center gap-1.5 border-l border-haze/60 pl-3 md:pl-6">
              <button id="btn-zoom-out" class="hover:text-caprock transition-colors p-1 md:p-1.5 rounded-sm hover:bg-iron/5 focus:outline-none" aria-label="Zoom Out" title="Zoom Out">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              </button>
              <button id="btn-zoom-reset" class="hover:text-caprock transition-colors p-1 md:p-1.5 rounded-sm hover:bg-iron/5 focus:outline-none" aria-label="Reset Zoom" title="Reset Zoom">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg>
              </button>
              <button id="btn-zoom-in" class="hover:text-caprock transition-colors p-1 md:p-1.5 rounded-sm hover:bg-iron/5 focus:outline-none" aria-label="Zoom In" title="Zoom In">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              </button>
            </div>
          </div>
          
          <!-- Right Controls (Fullscreen + Close) -->
          <div class="flex items-center gap-2 md:gap-4">
            <button id="btn-fullscreen" class="font-mono text-[10px] uppercase tracking-widest text-iron/50 hover:text-caprock transition-colors p-2 focus:outline-none flex items-center gap-1.5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path></svg>
              <span class="hidden md:inline">fullscreen</span>
            </button>
            
            <button id="close-lightbox" class="font-mono text-[10px] uppercase tracking-widest text-iron/50 hover:text-caprock transition-colors p-2 z-50 focus:outline-none">
              esc // close view
            </button>
          </div>
        </div>

        <!-- Dynamic Middle Image Container (Grows/Shrinks safely without pushing text off screen) -->
        <div class="w-full max-w-5xl mx-auto flex-1 min-h-0 flex items-center justify-center overflow-hidden my-4 relative">
          <button id="nav-prev" class="absolute left-0 md:-left-12 z-50 text-iron/30 hover:text-caprock transition-colors p-4 focus:outline-none hidden md:block">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          
          <img 
            id="lightbox-img" 
            src="" 
            alt="" 
            class="max-w-full max-h-full object-contain shadow-md border border-haze p-2 bg-canvas transition-transform duration-200 ease-out cursor-zoom-in relative z-40" 
            style="image-rendering: high-quality;"
            decoding="async"
          />

          <button id="nav-next" class="absolute right-0 md:-right-12 z-50 text-iron/30 hover:text-caprock transition-colors p-4 focus:outline-none hidden md:block">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>

        <!-- Bottom Metadata & Thumbnails (Locks to Bottom) -->
        <div class="w-full max-w-5xl mx-auto border-t border-haze/40 pt-4 pb-2 md:pb-4 shrink-0 pb-safe">
          <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 items-start font-mono text-[11px] uppercase tracking-wider text-sage">
            <div class="col-span-12 md:col-span-5 flex flex-col gap-1">
              <span id="lightbox-plate-title" class="font-semibold text-iron"></span>
              <div class="flex gap-4 text-iron/40 text-[10px] lowercase tracking-normal mt-0.5">
                <span id="lightbox-specs"></span>
                <span id="lightbox-coords"></span>
              </div>
            </div>
            <div class="col-span-12 md:col-span-7 border-t border-dashed border-haze/40 pt-3 md:pt-0 md:border-t-0 font-serif normal-case tracking-normal text-xs text-iron/70 italic leading-relaxed max-h-[12dvh] overflow-y-auto pr-2 scrollbar-none select-text touch-pan-y">
              <p id="lightbox-caption" class="cursor-text"></p>
            </div>
          </div>
          
          <div id="thumbnail-strip" class="w-full flex gap-2 overflow-x-auto scrollbar-none mt-4 md:mt-6 pt-2 pb-1 snap-x touch-pan-x">
            {gallery.plates.map((plate, index) => (
              <button 
                class="thumbnail-btn shrink-0 w-12 h-12 md:w-16 md:h-16 rounded-xs opacity-40 hover:opacity-100 transition-all border border-transparent focus:outline-none snap-center"
                data-index={index}
                aria-label={`Jump to Plate ${index + 1}`}
              >
                <img src={plate.src} class="w-full h-full object-cover rounded-xs pointer-events-none" alt={`Thumbnail ${index + 1}`} loading="lazy" />
              </button>
            ))}
          </div>
        </div>
      </div>
    </main>
</Layout>

<script>
  const viewport = document.getElementById('workspace-viewport');
  const table = document.getElementById('light-table');
  const modal = document.getElementById('lightbox-modal');
  const modalImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const modalTitle = document.getElementById('lightbox-plate-title');
  const modalSpecs = document.getElementById('lightbox-specs');
  const modalCoords = document.getElementById('lightbox-coords');
  const modalCaption = document.getElementById('lightbox-caption');
  const progressText = document.getElementById('lightbox-progress');
  const closeBtn = document.getElementById('close-lightbox');
  const triggers = document.querySelectorAll('[data-lightbox-trigger]');
  
  // Navigation & Toolbar Elements
  const thumbnails = document.querySelectorAll('.thumbnail-btn');
  const navPrev = document.getElementById('nav-prev');
  const navNext = document.getElementById('nav-next');
  const btnZoomIn = document.getElementById('btn-zoom-in');
  const btnZoomOut = document.getElementById('btn-zoom-out');
  const btnZoomReset = document.getElementById('btn-zoom-reset');
  const btnFullscreen = document.getElementById('btn-fullscreen');

  // HUD Layout Items
  const hudContainer = document.getElementById('fixed-hud-container');
  const hudToggle = document.getElementById('hud-toggle');
  const hudCollapsible = document.getElementById('hud-collapsible');
  const mobileInstructions = document.getElementById('mobile-instructions');
  const toggleText = document.getElementById('toggle-text');
  const toggleIcon = document.getElementById('toggle-icon');

  if (viewport && table && modal && modalImg) {
    // 1. Core State Variables
    let isDown = false;
    let startX = 0, startY = 0;
    let isDragging = false;
    let isExpanded = false;
    
    // Lightbox State
    let currentPlateIndex = 0;
    const totalPlates = triggers.length;
    let lightboxScale = 1; // Replaces binary boolean with strict numeric scale
    
    // Dynamically retrieve unique album coordinates
    const centerX = Number(table.dataset.centerX) || 1150;
    const centerY = Number(table.dataset.centerY) || 520;
    
    // Dynamic initialization
    let scale = window.innerWidth >= 768 ? 0.65 : 0.45;
    let panX = (window.innerWidth / 2) - (centerX * scale);
    let panY = (window.innerHeight / 2) - (centerY * scale);

    let initialTouchDist = 0;
    let initialTouchScale = 0;
    let initialPinchCenterX = 0;
    let initialPinchCenterY = 0;

    // Boundary clamping logic
    const constrainPan = () => {
      const scaledWidth = 3200 * scale;
      const scaledHeight = 2200 * scale;
      
      const minX = window.innerWidth / 2 - scaledWidth;
      const maxX = window.innerWidth / 2;
      const minY = window.innerHeight / 2 - scaledHeight;
      const maxY = window.innerHeight / 2;

      panX = Math.min(Math.max(panX, minX), maxX);
      panY = Math.min(Math.max(panY, minY), maxY);
    };

    const updateTransform = () => {
      constrainPan();
      table.style.transform = `translate(${panX}px, ${panY}px) scale(${scale})`;
    };

    updateTransform();

    const collapseHUD = () => {
      isExpanded = false;
      if (hudCollapsible) hudCollapsible.classList.add('hidden');
      if (mobileInstructions) mobileInstructions.classList.add('hidden');
      if (toggleText) toggleText.innerText = 'info';
      if (toggleIcon) toggleIcon.style.transform = 'rotate(0deg)';
      if (hudToggle) hudToggle.setAttribute('aria-expanded', 'false');
    };

    if (hudToggle && hudCollapsible && mobileInstructions) {
      hudToggle.addEventListener('click', (e) => {
        e.stopPropagation();
        isExpanded = !isExpanded;
        hudToggle.setAttribute('aria-expanded', isExpanded.toString());

        if (isExpanded) {
          hudCollapsible.classList.remove('hidden');
          mobileInstructions.classList.remove('hidden');
          if (toggleText) toggleText.innerText = 'close';
          if (toggleIcon) toggleIcon.style.transform = 'rotate(45deg)';
        } else {
          collapseHUD();
        }
      });
    }

    // DESKTOP: Precision Zoom Wheel Tracking for Mapping Desk
    viewport.addEventListener('wheel', (e) => {
      if (!modal.classList.contains('hidden')) return;

      e.preventDefault();
      
      const zoomFactor = 0.08;
      const targetScale = e.deltaY < 0 ? scale + zoomFactor : scale - zoomFactor;
      
      const minScale = 0.25; 
      const maxScale = 1.5;  
      const newScale = Math.min(Math.max(targetScale, minScale), maxScale);

      const rect = viewport.getBoundingClientRect();
      const mouseX = e.clientX - rect.left;
      const mouseY = e.clientY - rect.top;

      const baseXSpatial = (mouseX - panX) / scale;
      const baseYSpatial = (mouseY - panY) / scale;

      scale = newScale;
      panX = mouseX - baseXSpatial * scale;
      panY = mouseY - baseYSpatial * scale;

      updateTransform();
    }, { passive: false });

    // UNIFIED DRAG SYSTEM
    const startDrag = (clientX: number, clientY: number) => {
      isDown = true;
      isDragging = false;
      viewport.classList.replace('cursor-grab', 'cursor-grabbing');
      startX = clientX - panX;
      startY = clientY - panY;
      collapseHUD();
    };

    const moveDrag = (clientX: number, clientY: number) => {
      if (!isDown) return;
      isDragging = true;
      panX = clientX - startX;
      panY = clientY - startY;
      updateTransform();
    };

    const endDrag = () => {
      isDown = false;
      viewport.classList.replace('cursor-grabbing', 'cursor-grab');
    };

    viewport.addEventListener('mousedown', (e) => {
      if (!modal.classList.contains('hidden')) return;
      if ((e.target as HTMLElement).closest('#fixed-hud-container')) return;
      startDrag(e.clientX, e.clientY);
    });
    
    viewport.addEventListener('mousemove', (e) => moveDrag(e.clientX, e.clientY));
    window.addEventListener('mouseup', endDrag);

    // MOBILE TOUCH ENGINE
    viewport.addEventListener('touchstart', (e) => {
      if (!modal.classList.contains('hidden')) return;

      if (e.touches.length === 2) {
        isDown = false; 
        initialTouchDist = Math.hypot(
          e.touches[0].clientX - e.touches[1].clientX,
          e.touches[0].clientY - e.touches[1].clientY
        );
        initialTouchScale = scale;
        
        initialPinchCenterX = (e.touches[0].clientX + e.touches[1].clientX) / 2;
        initialPinchCenterY = (e.touches[0].clientY + e.touches[1].clientY) / 2;
        return;
      }
      
      if ((e.target as HTMLElement).closest('#fixed-hud-container')) return;
      if (e.touches.length === 1) {
        startDrag(e.touches[0].clientX, e.touches[0].clientY);
      }
    }, { passive: true });

    viewport.addEventListener('touchmove', (e) => {
      if (!modal.classList.contains('hidden')) return;

      if (e.touches.length === 1 && isDown) {
        moveDrag(e.touches[0].clientX, e.touches[0].clientY);
      } else if (e.touches.length === 2 && initialTouchDist > 0) {
        e.preventDefault(); 
        const currentDist = Math.hypot(
          e.touches[0].clientX - e.touches[1].clientX,
          e.touches[0].clientY - e.touches[1].clientY
        );
        
        const targetTouchScale = (currentDist / initialTouchDist) * initialTouchScale;
        const newScale = Math.min(Math.max(targetTouchScale, 0.25), 1.5);

        const baseXSpatial = (initialPinchCenterX - panX) / scale;
        const baseYSpatial = (initialPinchCenterY - panY) / scale;

        scale = newScale;
        panX = initialPinchCenterX - baseXSpatial * scale;
        panY = initialPinchCenterY - baseYSpatial * scale;

        updateTransform();
      }
    }, { passive: false });

    viewport.addEventListener('touchend', (e) => {
      if (e.touches.length === 0) {
        endDrag();
        initialTouchDist = 0;
      }
    });

    // --- NEW: CENTRALIZED LIGHTBOX SCALAR ZOOM ENGINE ---
    
    const applyLightboxTransform = () => {
      modalImg.style.transform = `scale(${lightboxScale})`;
      if (lightboxScale === 1) {
        modalImg.style.cursor = 'zoom-in';
        modalImg.style.transformOrigin = 'center center';
      } else {
        modalImg.style.cursor = 'grab';
      }
    };

    const resetLightboxZoom = () => {
      lightboxScale = 1;
      applyLightboxTransform();
    };

    const adjustLightboxZoom = (delta: number) => {
      lightboxScale = Math.min(Math.max(lightboxScale + delta, 1), 4);
      applyLightboxTransform();
    };

    // Bind explicit UI Toolbar Controls
    btnZoomIn?.addEventListener('click', (e) => { e.stopPropagation(); adjustLightboxZoom(0.5); });
    btnZoomOut?.addEventListener('click', (e) => { e.stopPropagation(); adjustLightboxZoom(-0.5); });
    btnZoomReset?.addEventListener('click', (e) => { e.stopPropagation(); resetLightboxZoom(); });

    // Enable precision scroll wheel zooming inside the Lightbox
    modalImg.parentElement?.addEventListener('wheel', (e) => {
      if (modal.classList.contains('hidden')) return;
      e.preventDefault();
      
      const zoomVelocity = 0.15;
      if (e.deltaY < 0) {
        lightboxScale = Math.min(lightboxScale + zoomVelocity, 4);
      } else {
        lightboxScale = Math.max(lightboxScale - zoomVelocity, 1);
      }
      
      // Keep focal point centered dynamically as user wheels over the image
      if (lightboxScale > 1) {
        const container = modalImg.parentElement;
        if (container) {
          const rect = container.getBoundingClientRect();
          const x = ((e.clientX - rect.left) / rect.width) * 100;
          const y = ((e.clientY - rect.top) / rect.height) * 100;
          modalImg.style.transformOrigin = `${Math.min(Math.max(x, 0), 100)}% ${Math.min(Math.max(y, 0), 100)}%`;
        }
      }
      applyLightboxTransform();
    }, { passive: false });

    // Native Fullscreen API Integration
    btnFullscreen?.addEventListener('click', (e) => {
      e.stopPropagation();
      if (!document.fullscreenElement) {
        modal.requestFullscreen().catch((err) => console.log(`Error attempting to enable fullscreen: ${err.message}`));
      } else {
        document.exitFullscreen();
      }
    });

    const updateThumbnails = (activeIndex: number) => {
      thumbnails.forEach((thumb, i) => {
        if (i === activeIndex) {
          thumb.classList.add('opacity-100', 'border-caprock');
          thumb.classList.remove('opacity-40', 'border-transparent');
          thumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        } else {
          thumb.classList.remove('opacity-100', 'border-caprock');
          thumb.classList.add('opacity-40', 'border-transparent');
        }
      });
    };

    const loadPlate = (index: number) => {
      if (index < 0) index = totalPlates - 1;
      if (index >= totalPlates) index = 0;
      
      currentPlateIndex = index;
      const el = triggers[index] as HTMLElement;
      
      resetLightboxZoom();

      modalImg.src = el.dataset.src || '';
      modalImg.alt = el.dataset.title || '';
      
      if (modalTitle) modalTitle.innerHTML = `<span class="text-iron/40">${el.dataset.plate}</span> &bull; ${el.dataset.title}`;
      if (modalSpecs) modalSpecs.innerText = el.dataset.specs || '';
      if (modalCoords) modalCoords.innerText = el.dataset.coords || '';
      if (modalCaption) modalCaption.innerText = el.dataset.caption || '';
      
      if (progressText) progressText.innerText = `Plate ${index + 1} of ${totalPlates}`;

      updateThumbnails(index);
    };

    triggers.forEach((trigger, index) => {
      trigger.addEventListener('click', () => {
        if (isDragging) return;
        modal.classList.remove('hidden');
        setTimeout(() => modal.classList.remove('opacity-0'), 10);
        loadPlate(index);
      });
    });

    thumbnails.forEach((thumb) => {
      thumb.addEventListener('click', (e) => {
        e.stopPropagation(); 
        const targetIndex = parseInt((thumb as HTMLElement).dataset.index || '0', 10);
        loadPlate(targetIndex);
      });
    });

    navPrev?.addEventListener('click', (e) => { e.stopPropagation(); loadPlate(currentPlateIndex - 1); });
    navNext?.addEventListener('click', (e) => { e.stopPropagation(); loadPlate(currentPlateIndex + 1); });

    const closeLightbox = () => {
      modal.classList.add('opacity-0');
      setTimeout(() => {
        modal.classList.add('hidden');
        resetLightboxZoom(); 
        if (document.fullscreenElement) document.exitFullscreen(); // Exit fullscreen on modal close
      }, 300);
    };

    modal.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (
        target.closest('#lightbox-caption') || 
        target === modalImg || 
        target.closest('#thumbnail-strip') ||
        target.closest('button')
      ) return;
      closeLightbox();
    });
    
    closeBtn?.addEventListener('click', closeLightbox);

    // --- ACCESSIBILITY & KEYBOARD SYSTEM ---
    window.addEventListener('keydown', (e) => { 
      if (!modal.classList.contains('hidden')) {
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowRight') loadPlate(currentPlateIndex + 1);
        if (e.key === 'ArrowLeft') loadPlate(currentPlateIndex - 1);
        if (e.key === '=' || e.key === '+') adjustLightboxZoom(0.5); // Keyboard shortcut for Zoom In
        if (e.key === '-') adjustLightboxZoom(-0.5); // Keyboard shortcut for Zoom Out
        return;
      }

      const step = 40; 
      let triggered = false;

      if (e.key === 'ArrowUp' || e.key === 'w')    { panY += step; triggered = true; }
      if (e.key === 'ArrowDown' || e.key === 's')  { panY -= step; triggered = true; }
      if (e.key === 'ArrowLeft' || e.key === 'a')  { panX += step; triggered = true; }
      if (e.key === 'ArrowRight' || e.key === 'd') { panX -= step; triggered = true; }

      if (triggered) {
        e.preventDefault();
        collapseHUD();
        updateTransform();
      }
    });
    
    // Quick Click Zoom Toggle
    modalImg.addEventListener('click', (e) => {
      if (lightboxScale === 1) {
        lightboxScale = 2.5;
        const rect = modalImg.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        modalImg.style.transformOrigin = `${x}% ${y}%`;
      } else {
        lightboxScale = 1;
      }
      applyLightboxTransform();
    });

    const panZoomedImage = (clientX: number, clientY: number) => {
      if (lightboxScale === 1) return;
      const container = modalImg.parentElement;
      if (!container) return;
      
      const rect = container.getBoundingClientRect();
      const x = ((clientX - rect.left) / rect.width) * 100;
      const y = ((clientY - rect.top) / rect.height) * 100;
      
      const clampedX = Math.min(Math.max(x, 0), 100);
      const clampedY = Math.min(Math.max(y, 0), 100);
      
      modalImg.style.transformOrigin = `${clampedX}% ${clampedY}%`;
    };

    modalImg.parentElement?.addEventListener('mousemove', (e) => {
      panZoomedImage(e.clientX, e.clientY);
    });

    modalImg.parentElement?.addEventListener('touchmove', (e) => {
      if (e.touches.length === 1 && lightboxScale > 1) {
        e.preventDefault(); 
        panZoomedImage(e.touches[0].clientX, e.touches[0].clientY);
      }
    }, { passive: false });
  }
</script>

