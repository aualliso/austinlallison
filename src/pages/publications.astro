---
// src/pages/publications.astro
import RootLayout from '../layouts/RootLayout.astro';
---

<RootLayout title="Scholarship & Publications | Austin Allison">
  <div class="max-w-4xl mx-auto py-6 text-iron">
    
    <header class="border-b-2 border-caprock pb-4 mb-12 flex justify-between items-baseline">
      <h1 class="font-serif text-3xl font-medium tracking-tight text-iron">Scholarship & Research</h1>
      <span class="text-xs font-mono text-sage lowercase font-semibold">Open Access Repository</span>
    </header>

    <div class="space-y-16">
      
      <!-- JOURNAL ARTICLES -->
      <section class="space-y-6">
        <h2 class="text-sm font-mono text-sage uppercase tracking-widest font-bold flex items-center gap-2">
          <span>&bull;</span> Peer-Reviewed Journal Articles
        </h2>
        
        <div class="space-y-8 pl-4 border-l border-haze">
          <!-- Article 1 -->
          <div class="group">
            <span class="text-xs font-mono text-caprock font-semibold block mb-1">January 2026</span>
            <h3 class="font-serif text-xl font-medium tracking-tight text-iron group-hover:text-caprock transition-colors duration-300">
              Surveying the Capitol Land Reservation in Texas
            </h3>
            <p class="text-sm text-iron/70 mt-1">
              Southwestern Historical Quarterly &bull; Vol. 129, No. 3, pp. 335-364
            </p>
            <div class="mt-4 flex gap-3 text-xs font-mono">
              <a href="/publications/capitol_land" class="px-3 py-1.5 bg-caprock text-canvas rounded-sm hover:bg-iron transition-colors">
                read full text
              </a>
            </div>
          </div>
          <!-- Article 2 -->
          <div class="group">
            <span class="text-xs font-mono text-caprock font-semibold block mb-1">January 2026</span>
            <h3 class="font-serif text-xl font-medium tracking-tight text-iron group-hover:text-caprock transition-colors duration-300">
              ‘Opportunity Knocking’: The Vaughan Land Company and Early Bailey County Development.
            </h3>
            <p class="text-sm text-iron/70 mt-1">
              Panhandle-Plains Historical Review &bull; Vol. 96.
            </p>
            <div class="mt-4 flex gap-3 text-xs font-mono">
              <a href="/publications/opportunity_knocking" class="px-3 py-1.5 bg-caprock text-canvas rounded-sm hover:bg-iron transition-colors">
                read full text 
              </a>
            </div>
          </div>
          <!-- Article 3 -->
          <div class="group">
            <span class="text-xs font-mono text-caprock font-semibold block mb-1">2019</span>
            <h3 class="font-serif text-xl font-medium tracking-tight text-iron group-hover:text-caprock transition-colors duration-300">
             A Spring Sprung It: Tracing and Understanding the True Genesis of North America's Longest River.
            </h3>
            <p class="text-sm text-iron/70 mt-1">
              Journal of the West | Volume 58, Number 3 | 2019 | Pages 6-21
            </p>
            <div class="mt-4 flex gap-3 text-xs font-mono">
              <a href="/publications/spring spring_sprung_it" class="px-3 py-1.5 bg-caprock text-canvas rounded-sm hover:bg-iron transition-colors">
                read full text 
              </a>
            </div>
          </div>
          <!-- Article 4 -->
          <div class="group">
            <span class="text-xs font-mono text-caprock font-semibold block mb-1">2019</span>
            <h3 class="font-serif text-xl font-medium tracking-tight text-iron group-hover:text-caprock transition-colors duration-300">
             Maps and Newspapers in the Southwest Collection
            </h3>
            <p class="text-sm text-iron/70 mt-1">
              Archivation Exploration | Volume 3, Number 2 | 2018
            </p>
            <div class="mt-4 flex gap-3 text-xs font-mono">
              <a href="/publications/maps_and_newspapers" class="px-3 py-1.5 bg-caprock text-canvas rounded-sm hover:bg-iron transition-colors">
                read full text 
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- PUBLIC SCHOLARSHIP MAGAZINE CARDS -->
      <section class="space-y-6">
        <h2 class="text-sm font-mono text-sage uppercase tracking-widest font-bold flex items-center gap-2">
          <span>&bull;</span> Magazines & Trade Publications
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Card 1 -->
          <div class="border-t-4 border-t-caprock border-x border-b border-haze p-6 rounded-sm bg-haze/10 flex flex-col justify-between hover:shadow-sm transition-all group">
            <div class="space-y-2">
              <span class="text-[10px] font-mono uppercase tracking-wider text-sage font-bold block">Authentic Texas &bull; Summer 2025</span>
              <h3 class="font-serif text-lg font-medium tracking-tight text-iron group-hover:text-caprock transition-colors">
                Lipscomb County Courthouse: A Prairie Landmark with Enduring Presence
              </h3>
            </div>
            <a href="/publications/lipscomb_county_courthouse" class="text-xs font-mono text-caprock font-semibold hover:text-iron mt-6 inline-block">
              read full article &rarr;
            </a>
          </div>

          <!-- Card 2 -->
          <div class="border-t-4 border-t-caprock border-x border-b border-haze p-6 rounded-sm bg-haze/10 flex flex-col justify-between hover:shadow-sm transition-all group">
            <div class="space-y-2">
              <span class="text-[10px] font-mono uppercase tracking-wider text-sage font-bold block">Authentic Texas &bull; Winter 2024</span>
              <h3 class="font-serif text-lg font-medium tracking-tight text-iron group-hover:text-caprock transition-colors">
                The Remnants of the Southwest Conference: The Story of a Landmark Archival Collection
              </h3>
            </div>
            <a href="/publications/southwest_conference" class="text-xs font-mono text-caprock font-semibold hover:text-iron mt-6 inline-block">
              read full article &rarr;
            </a>
          </div>
          <!-- Card 3 -->
          <div class="border-t-4 border-t-caprock border-x border-b border-haze p-6 rounded-sm bg-haze/10 flex flex-col justify-between hover:shadow-sm transition-all group">
            <div class="space-y-2">
              <span class="text-[10px] font-mono uppercase tracking-wider text-sage font-bold block">Lubbock Avalanche-Journal &bull; January 28, 2024</span>
              <h3 class="font-serif text-lg font-medium tracking-tight text-iron group-hover:text-caprock transition-colors">
                The Sharps rifle, buffalo hunting, and the South Plains
              </h3>
            </div>
            <a href="/publications/sharps_rifle" class="text-xs font-mono text-caprock font-semibold hover:text-iron mt-6 inline-block">
              read full article &rarr;
            </a>
          </div>
          <!-- Card 4 -->
          <div class="border-t-4 border-t-caprock border-x border-b border-haze p-6 rounded-sm bg-haze/10 flex flex-col justify-between hover:shadow-sm transition-all group">
            <div class="space-y-2">
              <span class="text-[10px] font-mono uppercase tracking-wider text-sage font-bold block">Authentic Texas &bull; Spring 2023</span>
              <h3 class="font-serif text-lg font-medium tracking-tight text-iron group-hover:text-caprock transition-colors">
                Tumbleweed Smith and the Sounds of Texas
              </h3>
            </div>
            <a href="/publications/tumbleweed_smith" class="text-xs font-mono text-caprock font-semibold hover:text-iron mt-6 inline-block">
              read full article &rarr;
            </a>
          </div>
          <!-- Card 5 -->
          <div class="border-t-4 border-t-caprock border-x border-b border-haze p-6 rounded-sm bg-haze/10 flex flex-col justify-between hover:shadow-sm transition-all group">
            <div class="space-y-2">
              <span class="text-[10px] font-mono uppercase tracking-wider text-sage font-bold block">Authentic Texas &bull; Fall 2021</span>
              <h3 class="font-serif text-lg font-medium tracking-tight text-iron group-hover:text-caprock transition-colors">
                Comfortably Lodged: Transforming historic county jails into silos for historical and cultural heritage.
              </h3>
            </div>
            <a href="/publications/comfortably_lodged" class="text-xs font-mono text-caprock font-semibold hover:text-iron mt-6 inline-block">
              read full article &rarr;
            </a>
          </div>
          <!-- Card 6 -->
          <div class="border-t-4 border-t-caprock border-x border-b border-haze p-6 rounded-sm bg-haze/10 flex flex-col justify-between hover:shadow-sm transition-all group">
            <div class="space-y-2">
              <span class="text-[10px] font-mono uppercase tracking-wider text-sage font-bold block">Southwestern Archivist 42, Number 1 &bull; February 2019</span>
              <h3 class="font-serif text-lg font-medium tracking-tight text-iron group-hover:text-caprock transition-colors">
                Unusual Annotations in Stephen F. Austin's 1835 Map of Texas Tell Early Texas History
              </h3>
            </div>
            <a href="/publications/unusual_annotations" class="text-xs font-mono text-caprock font-semibold hover:text-iron mt-6 inline-block">
              read full article &rarr;
            </a>
          </div>
        </div>
      </section>

    <section class="space-y-6">
        <h2 class="text-sm font-mono text-sage uppercase tracking-widest font-bold flex items-center gap-2">
          <span>&bull;</span> Book Chapters
        </h2>
        <!-- Card 1 -->
          <div class="border-t-4 border-t-caprock border-x border-b border-haze p-6 rounded-sm bg-haze/10 flex flex-col justify-between hover:shadow-sm transition-all group">
            <div class="space-y-2">
              <span class="text-[10px] font-mono uppercase tracking-wider text-sage font-bold block">Caprock Chronicles: More Tales of the Llano Estacado, 2021</span>
              <h3 class="font-serif text-lg font-medium tracking-tight text-iron group-hover:text-caprock transition-colors">
                Tahoka Lake
              </h3>
            </div>
            <a href="/publications/tahoka_lake" class="text-xs font-mono text-caprock font-semibold hover:text-iron mt-6 inline-block">
              read full article &rarr;
            </a>
          </div>
    </section>

    </div>
  </div>
</RootLayout>