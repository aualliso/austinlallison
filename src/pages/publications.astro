---
// src/pages/publications.astro
import RootLayout from '../layouts/RootLayout.astro';
---

<RootLayout title="Research and Creative Activity | Austin Allison">
  <div class="max-w-4xl mx-auto py-6 text-iron">
    <header class="border-b-2 border-caprock pb-4 mb-12 flex justify-between items-baseline">
      <h1 class="font-serif text-3xl font-medium tracking-tight text-iron">Scholarship & Research</h1>
    </header>
    <div class="space-y-16">
      <!-- JOURNAL ARTICLES -->
      <section class="space-y-6">
      <h2 class="text-sm font-mono text-sage uppercase tracking-widest font-bold flex items-center gap-2">
      <span>&bull;</span> Peer-Reviewed &amp; Journal Articles
      </h2>
      <div class="space-y-8 pl-4 border-l border-haze">
        <!-- Article 1 -->
        <div class="group flex flex-col sm:flex-row gap-5 items-start">
        <!-- Thumbnail Image -->
          <div class="w-full sm:w-24 md:w-28 shrink-0 aspect-[4/3] sm:aspect-square overflow-hidden bg-haze rounded-sm">
            <img 
                src="/images/wiley_notes.jpg" 
                alt="Image of H.A. Wiley's field notes" 
                class="w-full h-full object-cover filter group-hover:grayscale-100 transition-all duration-500"
            />
          </div>
        <!-- Text Content -->
        <div class="flex-1">
          <span class="text-xs font-mono text-caprock font-semibold block mb-1">January 2026</span>
          <h3 class="font-serif text-xl font-medium tracking-tight text-iron group-hover:text-caprock transition-colors duration-300">
            Surveying the Capitol Land Reservation in Texas
          </h3>
          <p class="text-sm text-iron/70 mt-1">
            Southwestern Historical Quarterly &bull; Volume 129, No. 3 &bull; 2026.
          </p>
          <div class="mt-4 flex gap-3 text-xs font-mono">
            <a href="/publications/capitol_land" class="px-3 py-1.5 bg-caprock text-canvas rounded-sm hover:bg-iron transition-colors">
              read full text
            </a>
          </div>
        </div>
        </div>
        <!-- Article 2 -->
        <div class="group flex flex-col sm:flex-row gap-5 items-start">
        <!-- Thumbnail Image -->
          <div class="w-full sm:w-24 md:w-28 shrink-0 aspect-[4/3] sm:aspect-square overflow-hidden bg-haze rounded-sm">
            <img 
                src="/images/vaughan_land_company.jpg" 
                alt="Advertisement for Vaughan Land Company" 
                class="w-full h-full object-cover filter group-hover:grayscale-100 transition-all duration-500"
            />
          </div>
        <!-- Text Content -->
        <div class="flex-1">
          <span class="text-xs font-mono text-caprock font-semibold block mb-1">2025</span>
          <h3 class="font-serif text-xl font-medium tracking-tight text-iron group-hover:text-caprock transition-colors duration-300">
            ‘Opportunity Knocking’: The Vaughan Land Company and Early Bailey County Development.
          </h3>
          <p class="text-sm text-iron/70 mt-1">
            Panhandle-Plains Historical Review &bull; Volume 96 &bull; 2025.
          </p>
          <div class="mt-4 flex gap-3 text-xs font-mono">
            <a href="/publications/opportunity_knocking" class="px-3 py-1.5 bg-caprock text-canvas rounded-sm hover:bg-iron transition-colors">
              read full text
            </a>
          </div>
        </div>
        </div>
        <!-- Article 3 -->
        <div class="group flex flex-col sm:flex-row gap-5 items-start">
        <!-- Thumbnail Image -->
          <div class="w-full sm:w-24 md:w-28 shrink-0 aspect-[4/3] sm:aspect-square overflow-hidden bg-haze rounded-sm">
            <img 
                src="/images/spring_sprung_it.jpg" 
                alt="Image of Missouri River Headwaters" 
                class="w-full h-full object-cover filter group-hover:grayscale-100 transition-all duration-500"
            />
          </div>
        <!-- Text Content -->
        <div class="flex-1">
          <span class="text-xs font-mono text-caprock font-semibold block mb-1">2019</span>
          <h3 class="font-serif text-xl font-medium tracking-tight text-iron group-hover:text-caprock transition-colors duration-300">
            A Spring Sprung It: Tracing and Understanding the True Genesis of North America's Longest River.
          </h3>
          <p class="text-sm text-iron/70 mt-1">
            Journal of the West &bull; Volume 58, Number 3 &bull; 2019.
          </p>
          <div class="mt-4 flex gap-3 text-xs font-mono">
            <a href="/publications/spring_sprung_it" class="px-3 py-1.5 bg-caprock text-canvas rounded-sm hover:bg-iron transition-colors">
              read full text
            </a>
          </div>
        </div>
        </div>
        <!-- Article 4 -->
        <div class="group flex flex-col sm:flex-row gap-5 items-start">
        <!-- Thumbnail Image -->
          <div class="w-full sm:w-24 md:w-28 shrink-0 aspect-[4/3] sm:aspect-square overflow-hidden bg-haze rounded-sm">
            <img 
                src="/images/der_texas.jpg" 
                alt="Der Texas Demokrat newspaper" 
                class="w-full h-full object-cover filter group-hover:grayscale-100 transition-all duration-500"
            />
          </div>
        <!-- Text Content -->
        <div class="flex-1">
          <span class="text-xs font-mono text-caprock font-semibold block mb-1">2018</span>
          <h3 class="font-serif text-xl font-medium tracking-tight text-iron group-hover:text-caprock transition-colors duration-300">
            Maps and Newspapers in the Southwest Collection
          </h3>
          <p class="text-sm text-iron/70 mt-1">
            Archivation Exploration &bull; Volume 3, Number 2 &bull; 2018.
          </p>
          <div class="mt-4 flex gap-3 text-xs font-mono">
            <a href="/publications/maps_and_newspapers" class="px-3 py-1.5 bg-caprock text-canvas rounded-sm hover:bg-iron transition-colors">
              read full text
            </a>
          </div>
        </div>
        </div>
        </div>
      </section>

      <!-- PUBLIC SCHOLARSHIP MAGAZINE CARDS -->
      <section class="space-y-6">
        <h2 class="text-sm font-mono text-sage uppercase tracking-widest font-bold flex items-center gap-2">
          <span>&bull;</span> Magazines & Trade Publications
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Card 1 -->
        <div class="border-t-4 border-t-caprock border-x border-b border-haze rounded-sm bg-haze/10 flex flex-col justify-between hover:shadow-sm transition-all group overflow-hidden">
          
          <!-- Text Content Container (Padded) -->
          <div class="p-6 pb-4 space-y-2">
            <span class="text-[10px] font-mono uppercase tracking-wider text-sage font-bold block">Authentic Texas &bull; Summer 2025</span>
            <h3 class="font-serif text-lg font-medium tracking-tight text-iron group-hover:text-caprock transition-colors">
              Lipscomb County Courthouse: A Prairie Landmark with Enduring Presence
            </h3>
            <a href="/publications/lipscomb_county_courthouse" class="text-xs font-mono text-caprock font-semibold hover:text-iron pt-2 inline-block">
              read full article &rarr;
            </a>
          </div>

          <!-- Bottom Full-Bleed Image -->
          <div class="w-full h-40 overflow-hidden bg-haze mt-auto border-t border-haze/50">
            <img 
              src="/images/lipscomb_county.jpg" 
              alt="Lipscomb County Courthouse" 
              class="w-full h-full object-cover filter group-hover:grayscale-100 transition-all duration-500"
            />
          </div>

        </div>
<!-- Card 2 -->
          <div class="border-t-4 border-t-caprock border-x border-b border-haze rounded-sm bg-haze/10 flex flex-col justify-between hover:shadow-sm transition-all group overflow-hidden">
            
            <!-- Text Content Container -->
            <div class="p-6 pb-4 space-y-2">
              <span class="text-[10px] font-mono uppercase tracking-wider text-sage font-bold block">Authentic Texas &bull; Winter 2024</span>
              <h3 class="font-serif text-lg font-medium tracking-tight text-iron group-hover:text-caprock transition-colors">
                The Remnants of the Southwest Conference: The Story of a Landmark Archival Collection
              </h3>
              <a href="/publications/southwest_conference" class="text-xs font-mono text-caprock font-semibold hover:text-iron pt-2 inline-block">
                read full article &rarr;
              </a>
            </div>

            <!-- Bottom Full-Bleed Image -->
            <div class="w-full h-40 overflow-hidden bg-haze mt-auto border-t border-haze/50">
              <img 
                src="/images/southwest_conference2.jpg" 
                alt="Southwest Conference archival memorabilia" 
                class="w-full h-full object-cover filter group-hover:grayscale-100 transition-all duration-500"
              />
            </div>
          </div>

          <!-- Card 3 -->
          <div class="border-t-4 border-t-caprock border-x border-b border-haze rounded-sm bg-haze/10 flex flex-col justify-between hover:shadow-sm transition-all group overflow-hidden">
            
            <!-- Text Content Container -->
            <div class="p-6 pb-4 space-y-2">
              <span class="text-[10px] font-mono uppercase tracking-wider text-sage font-bold block">Lubbock Avalanche-Journal &bull; January 28, 2024</span>
              <h3 class="font-serif text-lg font-medium tracking-tight text-iron group-hover:text-caprock transition-colors">
                The Sharps rifle, buffalo hunting, and the South Plains
              </h3>
              <a href="/publications/sharps_rifle" class="text-xs font-mono text-caprock font-semibold hover:text-iron pt-2 inline-block">
                read full article &rarr;
              </a>
            </div>

            <!-- Bottom Full-Bleed Image -->
            <div class="w-full h-40 overflow-hidden bg-haze mt-auto border-t border-haze/50">
              <img 
                src="/images/judia_buffalo_stand.jpg" 
                alt="Vintage Sharps rifle and historical buffalo hunting" 
                class="w-full h-full object-cover filter group-hover:grayscale-100 transition-all duration-500"
              />
            </div>
          </div>

          <!-- Card 4 -->
          <div class="border-t-4 border-t-caprock border-x border-b border-haze rounded-sm bg-haze/10 flex flex-col justify-between hover:shadow-sm transition-all group overflow-hidden">
            
            <!-- Text Content Container -->
            <div class="p-6 pb-4 space-y-2">
              <span class="text-[10px] font-mono uppercase tracking-wider text-sage font-bold block">Authentic Texas &bull; Spring 2023</span>
              <h3 class="font-serif text-lg font-medium tracking-tight text-iron group-hover:text-caprock transition-colors">
                Tumbleweed Smith and the Sounds of Texas
              </h3>
              <a href="/publications/tumbleweed_smith" class="text-xs font-mono text-caprock font-semibold hover:text-iron pt-2 inline-block">
                read full article &rarr;
              </a>
            </div>

            <!-- Bottom Full-Bleed Image -->
            <div class="w-full h-40 overflow-hidden bg-haze mt-auto border-t border-haze/50">
              <img 
                src="/images/tumbleweed_smith.jpg" 
                alt="Tumbleweed Smith recording audio in Texas" 
                class="w-full h-full object-cover filter group-hover:grayscale-100 transition-all duration-500"
              />
            </div>
          </div>

          <!-- Card 5 -->
          <div class="border-t-4 border-t-caprock border-x border-b border-haze rounded-sm bg-haze/10 flex flex-col justify-between hover:shadow-sm transition-all group overflow-hidden">
            
            <!-- Text Content Container -->
            <div class="p-6 pb-4 space-y-2">
              <span class="text-[10px] font-mono uppercase tracking-wider text-sage font-bold block">Authentic Texas &bull; Fall 2021</span>
              <h3 class="font-serif text-lg font-medium tracking-tight text-iron group-hover:text-caprock transition-colors">
                Comfortably Lodged: Transforming historic county jails into silos for historical and cultural heritage.
              </h3>
              <a href="/publications/comfortably_lodged" class="text-xs font-mono text-caprock font-semibold hover:text-iron pt-2 inline-block">
                read full article &rarr;
              </a>
            </div>

            <!-- Bottom Full-Bleed Image -->
            <div class="w-full h-40 overflow-hidden bg-haze mt-auto border-t border-haze/50">
              <img 
                src="/images/comfortably_lodged/comfortably_lodged2.jpg" 
                alt="Historic Texas county jail converted to museum" 
                class="w-full h-full object-cover filter group-hover:grayscale-100 transition-all duration-500"
              />
            </div>
          </div>

          <!-- Card 6 -->
          <div class="border-t-4 border-t-caprock border-x border-b border-haze rounded-sm bg-haze/10 flex flex-col justify-between hover:shadow-sm transition-all group overflow-hidden">
            
            <!-- Text Content Container -->
            <div class="p-6 pb-4 space-y-2">
              <span class="text-[10px] font-mono uppercase tracking-wider text-sage font-bold block">Southwestern Archivist 42, Number 1 &bull; February 2019</span>
              <h3 class="font-serif text-lg font-medium tracking-tight text-iron group-hover:text-caprock transition-colors">
                Unusual Annotations in Stephen F. Austin's 1835 Map of Texas Tell Early Texas History
              </h3>
              <a href="/publications/unusual_annotations" class="text-xs font-mono text-caprock font-semibold hover:text-iron pt-2 inline-block">
                read full article &rarr;
              </a>
            </div>

            <!-- Bottom Full-Bleed Image -->
            <div class="w-full h-40 overflow-hidden bg-haze mt-auto border-t border-haze/50">
              <img 
                src="/images/unusual_annotations/unusual_annotations2.png" 
                alt="Detail of annotations on Stephen F. Austin's 1835 Map of Texas" 
                class="w-full h-full object-cover filter group-hover:grayscale-100 transition-all duration-500"
              />
            </div>
          </div>
        </div>
      </section>

    <section class="space-y-6">
        <h2 class="text-sm font-mono text-sage uppercase tracking-widest font-bold flex items-center gap-2">
          <span>&bull;</span> Book Chapters
        </h2>
        <!-- Card 1 -->
          <div class="border-t-4 border-t-caprock border-x border-b border-haze p-6 rounded-sm bg-haze/10 flex flex-col justify-between hover:shadow-sm transition-all group">
            <div class="space-y-2">
              <span class="text-[10px] font-mono uppercase tracking-wider text-sage font-bold block">Caprock Chronicles: More Tales of the Llano Estacado, 2021</span>
              <h3 class="font-serif text-lg font-medium tracking-tight text-iron group-hover:text-caprock transition-colors">
                Tahoka Lake
              </h3>
            </div>
            <a href="/publications/tahoka_lake" class="text-xs font-mono text-caprock font-semibold hover:text-iron mt-6 inline-block">
              read full article &rarr;
            </a>
          </div>
    </section>

    </div>
  </div>
</RootLayout>