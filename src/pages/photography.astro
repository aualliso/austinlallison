---
// src/pages/photography.astro
import RootLayout from '../layouts/RootLayout.astro';
import { Image } from 'astro:assets';

// Placeholder imports — swap these out for your real asset paths when ready
import montana2022 from '../assets/montana2022/137.jpg';
import montana2023 from '../assets/montana2022/20230430-074.jpg';
import dumont from '../assets/cotton_gins/dumont.jpg';
---

<RootLayout title="Photography | Austin Allison">
  <div class="max-w-6xl mx-auto py-6 text-iron">
    
    <!-- Minimalist Catalog Header -->
    <header class="border-b border-haze pb-4 mb-16 flex justify-between items-end">
      <div>
        <span class="text-xs font-mono text-sage uppercase tracking-widest block mb-1">Series I &mdash; III</span>
        <h1 class="font-serif text-2xl font-medium tracking-tight text-caprock">Visual Monographs</h1>
      </div>
    </header>

    <!-- THE BOOK SPREADS CONTAINER -->
    <div class="space-y-32">

      <!-- SPREAD 01: The Left-Heavy Landscape (American Escarpments) -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16 items-start">
        
        <!-- Left "Page": Large Featured Image Frame (Takes up 7 out of 12 columns) -->
        <div class="md:col-span-7 space-y-3">
          <div class="border border-iron/10 bg-dust/35 rounded-sm overflow-hidden p-3 bg-canvas shadow-lg">
            <div class="overflow-hidden aspect-[3/2]">
              <a href="/photography/escarpments/"><Image 
                src={montana2022} 
                alt="The Hoodoos of Little Jerusalem in Toole County, Montana" 
                class="w-full h-full object-cover hover:grayscale-100 transition-all duration-700 ease-out"
              /></a>
            </div>
          </div>
          <!-- Archival Ledger Label underneath -->
          <div class="flex justify-between items-baseline text-[11px] font-mono text-iron/50 px-1">
            <span>PLATE 1.05 &bull; LITTLE JERUSALEM</span>
          </div>
        </div>

        <!-- Right "Page": Editorial text and Folio (Takes up 5 out of 12 columns) -->
        <div class="md:col-span-5 h-full flex flex-col justify-between pt-4 md:pt-12 space-y-8">
          <div class="space-y-4">
            <!-- Large Page Folio Number -->
            <span class="font-serif text-5xl font-light text-sage/60 block leading-none select-none">I</span>
            
            <h2 class="font-serif text-2xl font-medium tracking-tight text-caprock hover:text-sage leading-snug">
              <a href="/photography/escarpments/">American Escarpments</a>
            </h2>
            
            <p class="text-sm text-iron/80 leading-relaxed font-sans max-w-sm">
              A gallery of the vertical escarpments outlining the edges of our country's plateaus. This collecton captures the jarring drops of these areas under natural light. Encompassing three states, this gallery only captures a small portion of our nations plateaus and escarpments.
            </p>
          </div>
          
          <div class="pt-4">
            <!-- <span class="text-[11px] font-mono text-caprock uppercase tracking-wider font-semibold block mb-1">Status</span> -->
             <!-- <span class="text-xs font-mono text-iron/60 block lowercase">archived plates &bull; 2025 corpus</span> -->
          </div>
        </div>

      </div>

      <!-- SPREAD 02: The Right-Heavy Portrait (Water on the Llano Estacado) -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16 items-start md:flex-row-reverse">
        
        <!-- Left Column: Book Context & Page Number (Takes up 5 columns, pushes right) -->
        <div class="md:col-span-5 md:order-1 h-full flex flex-col justify-between pt-4 md:pt-12 space-y-8 md:text-right md:items-end">
          <div class="space-y-4">
            <span class="font-serif text-5xl font-light text-sage/60 block leading-none select-none">II</span>
            
            <a href="/photography/water_on_the_llano_estacado/"><h2 class="font-serif text-2xl font-medium tracking-tight text-caprock hover:text-sage leading-snug">
              Water on the Llano Estacado
            </h2></a>
            
            <p class="text-sm text-iron/80 leading-relaxed font-sans max-w-sm">
              A documentary index isolating the diminutive watersources of the Llano Estacado.
            </p>
          </div>
          
          <div class="pt-4">
            <!-- <span class="text-[11px] font-mono text-sage uppercase tracking-wider font-semibold block mb-1">Methodology</span> -->
            <!-- <span class="text-xs font-mono text-iron/60 block lowercase">fixed aspect focal length &bull; drone survey</span> -->
          </div>
        </div>

        <!-- Right Column: Tall Portrait Image (Takes up 7 columns, holds left display) -->
        <div class="md:col-span-7 md:order-2 space-y-3">
          <div class="border border-iron/10 bg-dust/35 rounded-sm overflow-hidden p-3 bg-canvas shadow-lg max-w-md mx-auto md:ml-0">
            <!-- Forced 2:3 book portrait look -->
            <div class="bg-haze/30 aspect-[2/3] w-full flex items-center justify-center rounded-sm">
              <a href="/photography/water_on_the_llano_estacado/"><Image 
                src={montana2023} 
                alt="Tule Creek from above" 
                class="w-full h-full object-cover hover:grayscale-100 transition-all duration-700 ease-out"
              /></a>
            </div>
          </div>
          <div class="flex justify-between items-baseline text-[11px] font-mono text-iron/50 px-1 max-w-md mx-auto md:ml-0">
            <span>PLATE 2.01 &bull; TULE CREEK</span>
            <!-- <span>2026 INDEX</span> --> 
          </div>
        </div>

      </div>

    <!-- SPREAD 03: The Left-Heavy Landscape (Texas Cotton Gins) -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16 items-start">
        
        <!-- Left "Page": Large Featured Image Frame (Takes up 7 out of 12 columns) -->
        <div class="md:col-span-7 space-y-3">
          <div class="border border-iron/10 bg-dust/35 rounded-sm overflow-hidden p-3 bg-canvas shadow-lg">
            <div class="overflow-hidden aspect-[3/2]">
              <Image 
                src={dumont} 
                alt="Photograph of dilapidated cotton gin" 
                class="w-full h-full object-cover hover:grayscale-100 transition-all duration-700 ease-out"
              />
            </div>
          </div>
          <!-- Archival Ledger Label underneath -->
          <div class="flex justify-between items-baseline text-[11px] font-mono text-iron/50 px-1">
            <span>PLATE 3.01 &bull; TEXAS COTTON GINS</span>
          </div>
        </div>

        <!-- Right "Page": Editorial text and Folio (Takes up 5 out of 12 columns) -->
        <div class="md:col-span-5 h-full flex flex-col justify-between pt-4 md:pt-12 space-y-8">
          <div class="space-y-4">
            <!-- Large Page Folio Number -->
            <span class="font-serif text-5xl font-light text-sage/60 block leading-none select-none">III</span>
            
            <h2 class="font-serif text-2xl font-medium tracking-tight text-caprock leading-snug">
              Cotton Gins of Texas
            </h2>
            
            <p class="text-sm text-iron/80 leading-relaxed font-sans max-w-sm">
              An intentional survey of the remnant legacy cotton gins in West Texas. No longer in use, these sentinels of the plains register stories of economic prosperity dating back more than a century.
            </p>
          </div>
          
          <div class="pt-4">
            <!-- <span class="text-[11px] font-mono text-caprock uppercase tracking-wider font-semibold block mb-1">Status</span> -->
             <!-- <span class="text-xs font-mono text-iron/60 block lowercase">archived plates &bull; 2025 corpus</span> -->
          </div>
        </div>

      </div>

    </div>

  </div>
</RootLayout>