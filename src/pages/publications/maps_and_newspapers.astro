---
// src/pages/publications/maps_and_newspapers.astro
import RootLayout from '../../layouts/RootLayout.astro';
---

<RootLayout title="Maps and Newspapers in the Southwest Collection  | Austin Allison">
  <div class="max-w-7xl mx-auto py-6 text-iron">
    
    <!-- Breadcrumb Anchor Navigation -->
    <div class="mb-8">
      <a href="/publications" class="text-xs font-mono text-sage hover:text-caprock transition-colors lowercase tracking-wide">
        &larr; return to repository index
      </a>
    </div>

    <!-- The Split-Pane Layout Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      
      <!-- LEFT FLANK: Citation Details & Abstract (Spans 5 Columns) -->
      <div class="lg:col-span-5 space-y-6">
        <div class="space-y-2">
          <span class="text-xs font-mono text-caprock font-semibold uppercase tracking-wider block">Peer-Reviewed Article</span>
          <h1 class="font-serif text-2xl md:text-3xl font-medium tracking-tight text-iron leading-tight">
            Maps and Newspapers in the Southwest Collection 
          </h1>
          <p class="text-xs font-mono text-iron/60 pt-1">
            Published in <span class="italic font-sans text-iron font-medium">Archivation Exploration</span> &bull; Vol. 3, no. 2 (2018).
          </p>
        </div>

        <hr class="border-haze" />

        <div class="space-y-3">
          <h2 class="text-xs font-mono text-sage uppercase tracking-widest font-bold">Abstract</h2>
          <p class="text-sm text-iron/80 leading-relaxed font-sans">
            This document highlights unique archival materials held in the Southwest Collection, emphasizing their historical significance and the specialized preservation efforts used to maintain them. 
          </p>
        </div>

        <div class="pt-4 flex flex-wrap gap-3">
          <a href="/documents/maps_and_newspapers.pdf" download class="px-4 py-2 bg-iron text-canvas text-xs font-mono rounded-sm hover:bg-caprock transition-colors">
            download print-ready version
          </a>
        </div>
      </div>

      <!-- RIGHT FLANK: High-Fidelity Native Document View (Spans 7 Columns) -->
      <div class="lg:col-span-7 w-full">
        <div class="border border-haze rounded-sm p-2 bg-canvas shadow-sm">
          <!-- Inline frame displaying the hosted file directly with top fit constraints -->
          <iframe 
            src="/documents/maps_and_newspapers.pdf#view=FitH" 
            class="w-full h-[650px] rounded-xs" 
            title="Maps and Newspapers in the Southwest Collection  PDF Viewer"
            >
            <p class="text-sm p-4 font-mono">Your browser does not support inline frame displays. <a href="/documents/maps_and_newspapers.pdf" class="text-caprock underline">Click here to view file directly.</a></p>
          </iframe>
        </div>
        <div class="mt-2 text-center">
          <span class="text-[10px] font-mono text-iron/40 lowercase">scroll inside panel to read full pagination or use text selection controls</span>
        </div>
      </div>

    </div>

  </div>
</RootLayout>