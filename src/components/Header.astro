  /* ======================================================================== */
  /* SCROLL-DRIVEN ANIMATIONS (Chrome / Edge)                                 */
  /* ======================================================================== */
  @supports (animation-timeline: scroll()) {

    /* Disable fallback transitions so the two systems don't fight.
       Entrance animations and the `d` morph live on other elements/props. */
    #horizon-header, #sky-frost, #sky-dusk, #horizon-sun, #the-horizon,
    .signature-img, .landmark-name, .station-meta {
      transition: none;
    }

    /* 1. The sky lowers */
    @keyframes lower-sky {
      to { padding-top: 0.8rem; }
    }
    @media (min-width: 768px) {
      @keyframes lower-sky {
        to { padding-top: 1rem; }
      }
    }
    #horizon-header {
      animation: lower-sky linear both;
      animation-timeline: scroll(root block);
      animation-range: 0px 120px;
    }

    /* 2. The frost settles for pinned legibility (opacity + blur only —
       both interpolate; the sky gradient itself never animates) */
    @keyframes frost-sky {
      to {
        opacity: 1;
        backdrop-filter: blur(10px);
      }
    }
    #sky-frost {
      animation: frost-sky linear both;
      animation-timeline: scroll(root block);
      animation-range: 0px 120px;
    }

    /* 3. Evening rises slowly — a full-page-depth effect, not a threshold */
    @keyframes dusk-rise {
