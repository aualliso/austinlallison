    .station-meta {
      animation: fade-meta linear both;
      animation-timeline: scroll(root block);
      animation-range: 0px 100px;
    }
  }

  /* ======================================================================== */
  /* REDUCED MOTION — states still change (via .is-scrolled, which JS always  */
