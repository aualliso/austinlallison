    @keyframes sun-set {
      70%  { opacity: 0.9; }
      100% { transform: translateY(500%); opacity: 0; }
    }
    #horizon-sun {
      animation: sun-set linear both;
      animation-timeline: scroll(root block);
      animation-range: 0px 400px;
    }

    /* 5. The horizon deepens against the evening (composes with the
       phase baseline — night starts darker and still deepens to iron) */
    @keyframes deepen-horizon {
      to { color: var(--color-iron, #1A1919); }
    }
    #the-horizon {
      animation: deepen-horizon linear both;
      animation-timeline: scroll(root block);
      animation-range: 0px 300px;
    }

    /* 6. The landmark recedes slightly, feet still on the line */
    @keyframes recede-signature {
